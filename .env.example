# Supabase — from your project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe — publishable key from your Stripe dashboard
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe price IDs — create products in Stripe dashboard, paste price IDs here
VITE_STRIPE_PRICE_MONTHLY=price_...
VITE_STRIPE_PRICE_FORTNIGHTLY=price_...
VITE_STRIPE_PRICE_WEEKLY=price_...

# Stripe secret key — for Netlify Functions (do NOT prefix with VITE_)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service role key — for Netlify Functions only (do NOT prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
