# Supabase — from your project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe — publishable key from your Stripe dashboard
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe price IDs — create products in Stripe dashboard, paste price IDs here
VITE_STRIPE_PRICE_MONTHLY=price_...
VITE_STRIPE_PRICE_FORTNIGHTLY=price_...
VITE_STRIPE_PRICE_WEEKLY=price_...

# Stripe secret key — for Netlify Functions (do NOT prefix with VITE_)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service role key — for Netlify Functions only (do NOT prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Calendly webhook signing secret — set when you create the webhook subscription
# in Calendly's developer dashboard. Used by netlify/functions/calendly-webhook.js
# to verify incoming requests.
CALENDLY_WEBHOOK_SECRET=your-calendly-webhook-secret

# Resend (transactional email) — used by netlify/functions/send-email.js
RESEND_API_KEY=re_...
EMAIL_FROM=hello@ourpathguidance.co.uk

# Notion (blog content) — used by netlify/functions/blog.js
# Create an internal integration at https://www.notion.so/profile/integrations
# then share the "OurPath Blog" database page with it.
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=1dd52d69-3050-4ed4-a85d-130bde572558
